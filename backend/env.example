# fastapi config
DEBUG=True
VERSION=0.1.0
ALLOWED_HOSTS=*

# DB
POSTGRES_USER=userdb
POSTGRES_PASSWORD=passworddb
POSTGRES_DB=postgresdb
POSTGRES_HOST=db
POSTGRES_PORT=5432

# logging config
LOG_LEVEL=DEBUG
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# Blockchain
POLYGON_RPC_URL=
POLYGON_CHAIN_ID=137
ETHERSCAN_API_URL=https://api.etherscan.io/v2/api/
ETHERSCAN_API_KEY=

# Polymarket APIs (sin auth)
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com/
POLYMARKET_DATA_API=https://data-api.polymarket.com/
POLYMARKET_CLOB_API=https://clob.polymarket.com/
POLYMARKET_CLOB_WS=wss://ws-subscriptions-clob.polymarket.com/

ALCHEMY_API_KEY=

# Redis (worker / arq — required for scheduled external-signals ingestion)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Workers
CHAINLINK_POLL_INTERVAL_SECONDS=60
MARKET_PRICE_POLL_INTERVAL_SECONDS=300
MARKET_PRICE_INTERVAL=1h
MARKET_PRICE_FIDELITY=1
MARKETS_INGEST_INTERVAL_SECONDS=1800
MARKETS_INGEST_LIMIT=100

# Divergence
DIVERGENCE_WINDOW_MINUTES=60
DIVERGENCE_GAP_MIN_PCT=5.0
DIVERGENCE_EXT_MOVE_MIN_PCT=8.0
DIVERGENCE_MKT_FLAT_MAX_PCT=2.0
DIVERGENCE_SEVERITY_BUCKETS=5:1,8:2,12:3,20:4
DIVERGENCE_CALC_INTERVAL_MINUTES=10
DIVERGENCE_MINI_CHART_HOURS=24

# External signals
EXTERNAL_SIGNALS_ENABLED=true
EXTERNAL_SIGNALS_SOCIAL_ENABLED=true
EXTERNAL_SIGNALS_X_SEARCH_ENABLED=false
EXTERNAL_SIGNALS_X_PROFILE_ENABLED=true
EXTERNAL_SIGNALS_X_ACCOUNTS=WatcherGuru,WuBlockchain,Cointelegraph,TheBlock__,BitcoinMagazine,Polymarket
EXTERNAL_SIGNALS_X_NITTER_BASES=https://nitter.net

EXTERNAL_SIGNALS_TELEGRAM_ENABLED=true
EXTERNAL_SIGNALS_TELEGRAM_SCRAPE_ENABLED=true
EXTERNAL_SIGNALS_TELEGRAM_SCRAPE_MAX_POSTS_PER_CHANNEL=50
# Canales públicos de alta señal (usernames sin @, separados por coma)
EXTERNAL_SIGNALS_TELEGRAM_CHANNELS=watcherguru,WuBlockchain,cointelegraph,TheBlockCrypto,BitcoinMagazine,DeFiLlama

# Opcional — el resto usa defaults en settings.py (worker ingesta cada hora; trigger manual: POST /api/v1/external-signals/collect)
# EXTERNAL_SIGNALS_COLLECT_INTERVAL_SECONDS=3600
# EXTERNAL_SIGNALS_X_MAX_BASES=2
# EXTERNAL_SIGNALS_X_MAX_TERMS_PER_MARKET=3
# EXTERNAL_SIGNALS_X_ADDITIONAL_FEEDS=
# EXTERNAL_SIGNALS_TELEGRAM_ADDITIONAL_FEEDS=
# EXTERNAL_SIGNALS_GLOBAL_FEEDS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://feeds.reuters.com/reuters/topNews
# EXTERNAL_SIGNALS_MAX_AGE_DAYS=30
# EXTERNAL_SIGNALS_MIN_MATCH_SCORE=0.05
# EXTERNAL_SIGNALS_MAX_PER_MARKET=25
# EXTERNAL_SIGNALS_REQUEST_DELAY_SECONDS=0.35
# EXTERNAL_SIGNALS_RSS_TIMEOUT_SECONDS=15
